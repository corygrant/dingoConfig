    <_ContentIncludedByDefault Remove="Components\Devices\Functions\RotarySwitchGrid.razor" />
    <_ContentIncludedByDefault Remove="Components\Devices\Functions\StarterDisableConfig.razor" />
    <_ContentIncludedByDefault Remove="Components\Devices\Functions\VirtualInputsGrid.razor" />
    <_ContentIncludedByDefault Remove="Components\Devices\Functions\WiperConfig.razor" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="wwwroot\lib\" />
  </ItemGroup>

  <ItemGroup>
    <None Include="wwwroot\Icons\PTDPDM.svg" />
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="Components\Devices\FwDevice\Functions\AnalogInputsGrid.razor" />
    <AdditionalFiles Include="Components\Devices\FwDevice\Functions\BlinkMarineKeypad\BlinkMarineButtonsGrid.razor" />
    <AdditionalFiles Include="Components\Devices\FwDevice\Functions\BlinkMarineKeypad\BlinkMarineDeviceSettings.razor" />
    <AdditionalFiles Include="Components\Devices\FwDevice\Functions\BlinkMarineKeypad\BlinkMarineDialsGrid.razor" />
    <AdditionalFiles Include="Components\Devices\FwDevice\Functions\CanInputsGrid.razor" />
    <AdditionalFiles Include="Components\Devices\FwDevice\Functions\CanOutputsGrid.razor" />
    <AdditionalFiles Include="Components\Devices\FwDevice\Functions\ConditionsGrid.razor" />
    <AdditionalFiles Include="Components\Devices\FwDevice\Functions\CountersGrid.razor" />
    <AdditionalFiles Include="Components\Devices\FwDevice\Functions\DigitalInputsGrid.razor" />
