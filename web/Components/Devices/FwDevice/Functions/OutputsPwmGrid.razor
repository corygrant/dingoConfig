@using web.Services
@using domain.Devices.Functions
@inject NotificationService Notification
@typeparam TDevice where TDevice : domain.Interfaces.IDeviceConfigurable
@inherits FunctionComponentBase<TDevice>

<MudDataGrid Items="@Outputs" Dense="true" Hover="true" Striped="false" EditMode="DataGridEditMode.Cell" ReadOnly="false" 
             SortMode="SortMode.None" ColumnResizeMode="ResizeMode.Container" Virtualize="true" 
             FixedHeader="true" HorizontalScrollbar="true" Style="max-height: 400px;">
    <Columns>
        <PropertyColumn Property="x => x.Number" Title="#" StickyLeft="true" Editable="false" CellStyle="max-width: 100px"/>
        <PropertyColumn Property="x => x.PwmEnabled" Title="Enabled" CellStyle="max-width: 100px">
            <EditTemplate>
                <MudCheckBox @bind-Value="context.Item.PwmEnabled"
                             Disabled="!context.Item.Enabled || context.Item.PrimaryOutput >= 0"
                             Dense="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Name" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudTextField @bind-Value="context.Item.Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.CurrentDutyCycle" Title="Duty Cycle" Editable="false" CellStyle="max-width: 100px">
            <CellTemplate>
                <MudChip T="string"
                         Variant="Variant.Outlined"
                         Color="@(context.Item.CurrentDutyCycle > 0.0 ? Color.Success : Color.Default)"
                         Size="Size.Small" Style="min-width: 50px;">
                    @context.Item.CurrentDutyCycle
                </MudChip>
            </CellTemplate>
        </PropertyColumn>
        <TemplateColumn Title="Freq (Hz)" Resizable="true" CellStyle="max-width: 100px">
            <EditTemplate>
                <MudNumericField @key="@($"freq-{context.Item.Number}-{_refreshCounter}")"
                                 Value="@context.Item.Frequency"
                                 Disabled="!context.Item.PwmEnabled || context.Item.PrimaryOutput >= 0"
                                 ValueChanged="@((int val) => OnFrequencyChanged(context.Item, val))"/>
            </EditTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Fixed DC (%)" Resizable="true" CellStyle="max-width: 100px">
            <EditTemplate>
                <MudNumericField @key="@($"dc-{context.Item.Number}-{_refreshCounter}")"
                                 Value="@context.Item.FixedDutyCycle"
                                 Disabled="!context.Item.PwmEnabled || context.Item.PrimaryOutput >= 0"
                                 ValueChanged="@((int val) => OnDutyCycleChanged(context.Item, val))"/>
            </EditTemplate>
        </TemplateColumn>
        <PropertyColumn Property="x => x.VariableDutyCycle" Title="Variable DC" CellStyle="max-width: 100px">
            <EditTemplate>
                <MudCheckBox @bind-Value="context.Item.VariableDutyCycle" 
                             Dense="true" 
                             Disabled="!context.Item.PwmEnabled || context.Item.PrimaryOutput >= 0"/>
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.DutyCycleInput" Title="DC Var" CellStyle="max-width: 250px;">
            <EditTemplate>
                <MudStack Row="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Search"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   Disabled="(!context.Item.PwmEnabled) || context.Item.PrimaryOutput >= 0 || !context.Item.VariableDutyCycle"
                                   Style="max-width: 20px"
                                   OnClick="@(() => OpenVariableSelectorAsync(["int"], v => context.Item.DutyCycleInput = v))">
                    </MudIconButton>
                    <MudText>@GetSelectedVarText(context.Item.DutyCycleInput)</MudText>
                </MudStack>
            </EditTemplate>
        </PropertyColumn>
        <TemplateColumn Title="Variable DC Denom" Resizable="true" CellStyle="max-width: 100px">
            <EditTemplate>
                <MudNumericField @key="@($"dcDenom-{context.Item.Number}-{_refreshCounter}")"
                                 Value="@context.Item.DutyCycleDenominator"
                                 Disabled="!context.Item.PwmEnabled || context.Item.PrimaryOutput >= 0 || !context.Item.VariableDutyCycle"
                                 ValueChanged="@((int val) => OnDutyCycleDenominatorChanged(context.Item, val))"/>
            </EditTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Min DC (%)" Resizable="true" CellStyle="max-width: 100px">
            <EditTemplate>
                <MudNumericField @key="@($"mindc-{context.Item.Number}-{_refreshCounter}")"
                                 Value="@context.Item.MinDutyCycle"
                                 Disabled="!context.Item.PwmEnabled || context.Item.PrimaryOutput >= 0 || (!context.Item.VariableDutyCycle && !context.Item.SoftStartEnabled)"
                                 ValueChanged="@((int val) => OnMinDutyCycleChanged(context.Item, val))"/>
            </EditTemplate>
        </TemplateColumn>
        <PropertyColumn Property="x => x.SoftStartEnabled" Title="Soft Start" CellStyle="max-width: 100px">
            <EditTemplate>
                <MudCheckBox @bind-Value="context.Item.SoftStartEnabled" 
                             Dense="true" 
                             Disabled="!context.Item.PwmEnabled || context.Item.PrimaryOutput >= 0"/>
            </EditTemplate>
        </PropertyColumn>
        <TemplateColumn Title="SS Duration (ms)" Resizable="true" CellStyle="max-width: 100px">
            <EditTemplate>
                <MudNumericField @key="@($"ssRampTime-{context.Item.Number}-{_refreshCounter}")"
                                 Value="@context.Item.SoftStartRampTime"
                                 Disabled="!context.Item.PwmEnabled || context.Item.PrimaryOutput >= 0"
                                 ValueChanged="@((int val) => OnSoftStartRampTimeChanged(context.Item, val))"/>
            </EditTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    [Parameter, EditorRequired]
    public List<Output> Outputs { get; set; } = null!;

    private int _refreshCounter;
    
    private void OnFrequencyChanged(Output item, int value)
    {
        const int min = 0;
        const int max = 400;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{item.Name}.Frequency must be {min} to {max}");
        }
        item.Frequency = Math.Clamp(value, min, max);
        _refreshCounter++;
    }

    private void OnDutyCycleChanged(Output item, int value)
    {
        const int min = 0;
        const int max = 100;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{item.Name}.DutyCycle must be {min} to {max}");
        }
        item.FixedDutyCycle = Math.Clamp(value, min, max);
        _refreshCounter++;
    }
    
    private void OnMinDutyCycleChanged(Output item, int value)
    {
        const int min = 0;
        const int max = 100;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{item.Name}.MinDutyCycle must be {min} to {max}");
        }
        item.MinDutyCycle = Math.Clamp(value, min, max);
        _refreshCounter++;
    }

    private void OnDutyCycleDenominatorChanged(Output item, int value)
    {
        const int min = 1;
        const int max = 255;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{item.Name}.DutyCycleDenominator must be {min} to {max}");
        }
        item.DutyCycleDenominator = Math.Clamp(value, min, max);
        _refreshCounter++;
    }

    private void OnSoftStartRampTimeChanged(Output item, int value)
    {
        const int min = 0;
        const int max = 10000;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{item.Name}.SoftStartRampTime must be {min} to {max}");
        }
        item.SoftStartRampTime = Math.Clamp(value, min, max);
        _refreshCounter++;
    }

}
