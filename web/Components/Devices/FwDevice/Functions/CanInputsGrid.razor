@using web.Services
@using application.Models
@using application.Services
@using domain.Devices.Functions
@using domain.Enums
@inject NotificationService Notification
@inject IDialogService DialogService
@inject UserPreferencesManager UserPrefs
@typeparam TDevice where TDevice : domain.Interfaces.IDevice

<MudPaper MaxHeight="400">
    <MudDataGrid Items="@CanInputs" Dense="true" Hover="true" Striped="false" EditMode="DataGridEditMode.Cell"
                 ReadOnly="false"
                 SortMode="SortMode.None" ColumnResizeMode="ResizeMode.Container" Virtualize="true"
                 FixedHeader="true" HorizontalScrollbar="true" Style="max-height: 400px;">
        <Columns>
            <PropertyColumn Property="x => x.Number" Title="#" StickyLeft="true" Editable="false"
                            CellStyle="max-width: 100px"/>
            <PropertyColumn Property="x => x.Enabled" CellStyle="max-width: 100px">
                <EditTemplate>
                    <MudCheckBox @bind-Value="context.Item.Enabled" Dense="true"/>
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Name" CellStyle="max-width: 200px">
                <EditTemplate>
                    <MudTextField @bind-Value="context.Item.Name" Variant="Variant.Outlined" Margin="Margin.Dense"/>
                </EditTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Signals" StickyLeft="false" Sortable="false" Filterable="false"
                            CellStyle="max-width: 100px">
                <EditTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   Disabled="!context.Item.Enabled"
                                   OnClick="@(() => OpenSignalSelectorAsync(context.Item))"/>
                </EditTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Output" Title="Value" Editable="false" CellStyle="max-width: 100px">
                <CellTemplate>
                    <MudChip T="string"
                             Variant="Variant.Outlined"
                             Color="@(context.Item.Output ? Color.Success : Color.Default)"
                             Size="Size.Small" Style="min-width: 50px;">
                        @context.Item.Value
                    </MudChip>
                </CellTemplate>
            </PropertyColumn>
            <TemplateColumn Title="ID" Resizable="true" CellStyle="max-width: 100px">
                <EditTemplate>
                    <MudTextField @key="@($"id-{context.Item.Number}-{_refreshCounter}")"
                                  Value="@_id[context.Item.Number-1]"
                                  Disabled="!context.Item.Enabled"
                                  ValueChanged="@((string val) => @context.Item.Id = Utils.ParseId(val, UserPrefs.Preferences.IdFormat, Notification))"/>
                </EditTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Ide" Title="Extended" CellStyle="max-width: 100px">
                <EditTemplate>
                    <MudCheckBox @bind-Value="context.Item.Ide" Disabled="true" Dense="true"/>
                </EditTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Start Bit" Resizable="true" CellStyle="max-width: 100px">
                <EditTemplate>
                    <MudNumericField @key="@($"startBit-{context.Item.Number}-{_refreshCounter}")"
                                     Value="@context.Item.StartBit"
                                     Disabled="!context.Item.Enabled"
                                     ValueChanged="@((int val) => OnStartBitChanged(context.Item, val))"
                                     Step="1"/>
                </EditTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Bit Length" Resizable="true" CellStyle="max-width: 100px">
                <EditTemplate>
                    <MudNumericField @key="@($"bitLength-{context.Item.Number}-{_refreshCounter}")"
                                     Value="@context.Item.BitLength"
                                     Disabled="!context.Item.Enabled"
                                     ValueChanged="@((int val) => OnBitLengthChanged(context.Item, val))"
                                     Step="1"/>
                </EditTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Factor" Title="Factor" Resizable="true" CellStyle="max-width: 100px">
                <EditTemplate>
                    <MudNumericField @bind-Value="@context.Item.Factor"
                                     Disabled="!context.Item.Enabled"/>
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Offset" Title="Offset" Resizable="true" CellStyle="max-width: 100px">
                <EditTemplate>
                    <MudNumericField @bind-Value="@context.Item.Offset"
                                     Disabled="!context.Item.Enabled"/>
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Signed" CellStyle="max-width: 100px">
                <EditTemplate>
                    <MudCheckBox @bind-Value="context.Item.Signed" Dense="true"/>
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Operator" CellStyle="max-width: 200px">
                <EditTemplate>
                    <MudSelect T="Operator" @bind-Value="context.Item.Operator" Variant="Variant.Outlined" Dense="true"
                               Disabled="!context.Item.Enabled">
                        @foreach (Operator op in Enum.GetValues(typeof(Operator)))
                        {
                            <MudSelectItem T="Operator" Value="@op">@op</MudSelectItem>
                        }
                    </MudSelect>
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Operand" Title="Operand" Resizable="true" CellStyle="max-width: 100px">
                <EditTemplate>
                    <MudNumericField @bind-Value="@context.Item.Operand"
                                     Disabled="!context.Item.Enabled"/>
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Mode" CellStyle="max-width: 200px">
                <EditTemplate>
                    <MudSelect T="domain.Enums.InputMode" @bind-Value="context.Item.Mode" Variant="Variant.Outlined"
                               Disabled="!context.Item.Enabled" Dense="true">
                        @foreach (domain.Enums.InputMode mode in Enum.GetValues(typeof(domain.Enums.InputMode)))
                        {
                            <MudSelectItem T="domain.Enums.InputMode" Value="@mode">@mode</MudSelectItem>
                        }
                    </MudSelect>
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.TimeoutEnabled" Title="Timeout En" CellStyle="max-width: 100px">
                <EditTemplate>
                    <MudCheckBox @bind-Value="context.Item.TimeoutEnabled" Dense="true" Disabled="!context.Item.Enabled"/>
                </EditTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Timeout (ms)" Resizable="true" CellStyle="max-width: 150px">
                <EditTemplate>
                    <MudNumericField @key="@($"timeout-{context.Item.Number}-{_refreshCounter}")"
                                     Value="@context.Item.Timeout"
                                     Disabled="!context.Item.Enabled"
                                     ValueChanged="@((int val) => OnTimeoutChanged(context.Item, val))"/>
                </EditTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>
</MudPaper>

@code {
    [Parameter, EditorRequired] public List<CanInput> CanInputs { get; set; } = null!;
    [Parameter, EditorRequired] public TDevice Device { get; set; } = default!;
    
    private string[] _id = null!;
    
    private int _refreshCounter;

    protected override Task OnInitializedAsync()
    {
        _id = new string[CanInputs.Count];
        
        return Task.CompletedTask;
    }
    
    protected override void OnParametersSet()
    {
        foreach (var input in CanInputs)
        {
            _id[input.Number - 1] = Utils.FormatId(input.Id, UserPrefs.Preferences.IdFormat);
        }
        
        StateHasChanged();

        base.OnParametersSet();
    }

    private void OnBitLengthChanged(CanInput item, int value)
    {
        const int min = 1;
        const int max = 64;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{item.Name}.BitLength must be {min} to {max}");
        }

        item.BitLength = Math.Clamp(value, min, max);
        _refreshCounter++;
    }

    private void OnStartBitChanged(CanInput item, int value)
    {
        const int min = 0;
        const int max = 64;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{item.Name}.StartBit must be {min} to {max}");
        }

        item.StartBit = Math.Clamp(value, min, max);
        _refreshCounter++;
    }

    private void OnTimeoutChanged(CanInput item, int value)
    {
        const int min = 0;
        const int max = 60000;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{item.Name}.Timeout must be {min} to {max}");
        }

        item.Timeout = Math.Clamp(value, min, max);
        _refreshCounter++;
    }

    private async Task OpenSignalSelectorAsync(CanInput canInput)
    {
        var parameters = new DialogParameters<DbcSignalSelectionDialog>
        {
            { x => x.Device, Device}
        };
        
        var dialog = await DialogService.ShowAsync<DbcSignalSelectionDialog>("Select Signal", parameters);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is (DeviceSignalNode deviceNode, SignalNode signalNode))
        {
            MapSignalToCanInput(canInput, deviceNode, signalNode);
        }
    }

    private void MapSignalToCanInput(CanInput canInput, DeviceSignalNode deviceNode, SignalNode signalNode)
    {
        var signal = signalNode.Signal;

        canInput.Id = signal.Id;
        canInput.StartBit = signal.StartBit;
        canInput.BitLength = signal.Length;
        canInput.Factor = signal.Factor;
        canInput.Offset = signal.Offset;
        canInput.Signed = signal.IsSigned;
        canInput.Name = $"{deviceNode.DeviceName}.{signal.Name}";
        
        // Trigger UI refresh
        _refreshCounter++;
        StateHasChanged();
    }

}
