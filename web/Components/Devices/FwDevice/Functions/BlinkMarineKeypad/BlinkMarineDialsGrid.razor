@using domain.Devices.Functions.Keypad
@using web.Services
@inject NotificationService Notification
@typeparam TDevice where TDevice : domain.Devices.FwDevice

<MudDataGrid Items="@Dials" Dense="true" Hover="true" Striped="false" EditMode="DataGridEditMode.Cell" ReadOnly="false"
             SortMode="SortMode.None" ColumnResizeMode="ResizeMode.Container" Virtualize="false"
             FixedHeader="true" HorizontalScrollbar="true" Style="max-height: 400px;">
    <Columns>
        <PropertyColumn Property="x => x.Number" Title="#" StickyLeft="true" Editable="false" CellStyle="max-width: 100px"/>
        <PropertyColumn Property="x => x.Enabled" CellStyle="max-width: 100px">
            <EditTemplate>
                <MudCheckBox @bind-Value="context.Item.Enabled" Dense="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Name" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudTextField @bind-Value="context.Item.Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </EditTemplate>
        </PropertyColumn>
        <TemplateColumn Title="Min Count" Resizable="true" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudNumericField @key="@($"minCount-{context.Item.Number}-{_refreshCounter}")"
                                 Value="@context.Item.MinCount"
                                 Disabled="!context.Item.Enabled"
                                 ValueChanged="@((int val) => OnMinCountChanged(context.Item, val))"/>
            </EditTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Max Count" Resizable="true" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudNumericField @key="@($"maxCount-{context.Item.Number}-{_refreshCounter}")"
                                 Value="@context.Item.MaxCount"
                                 Disabled="!context.Item.Enabled"
                                 ValueChanged="@((int val) => OnMaxCountChanged(context.Item, val))"/>
            </EditTemplate>
        </TemplateColumn>
        <TemplateColumn Title="LED Offset" Resizable="true" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudNumericField @key="@($"ledOffset-{context.Item.Number}-{_refreshCounter}")"
                                 Value="@context.Item.LedOffset"
                                 Disabled="!context.Item.Enabled"
                                 ValueChanged="@((int val) => OnLedOffsetChanged(context.Item, val))"/>
            </EditTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Max Count (set by SDO)" Resizable="true" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudNumericField @key="@($"topPosition-{context.Item.Number}-{_refreshCounter}")"
                                 Value="@context.Item.TopPosition"
                                 Disabled="!context.Item.Enabled"
                                 ValueChanged="@((int val) => OnTopPositionChanged(context.Item, val))"/>
            </EditTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    [Parameter, EditorRequired]
    public IEnumerable<Dial> Dials { get; set; } = null!;
    [Parameter, EditorRequired] public TDevice Device { get; set; } = default!;
    
    private int _refreshCounter;

    private void OnMinCountChanged(Dial item, int value)
    {
        const int min = 1;
        const int max = 16;
        if (value < min || value > max)
            Notification.NewWarning($"{item.Name}.MinCount must be {min} to {max}");
        if (value > item.MaxCount)
            Notification.NewWarning($"{item.Name}.MinCount must be less than MaxLed");

        item.MinCount = Math.Clamp(value, min, max);

        _refreshCounter++;
    }
    
    private void OnMaxCountChanged(Dial item, int value)
    {
        const int min = 1;
        const int max = 16;
        if (value < min || value > max)
            Notification.NewWarning($"{item.Name}.MaxCount must be {min} to {max}");
        if (value < item.MinCount)
            Notification.NewWarning($"{item.Name}.MaxCount must be greater than MinLed");

        item.MaxCount = Math.Clamp(value, min, max);

        _refreshCounter++;
    }
    
    private void OnLedOffsetChanged(Dial item, int value)
    {
        const int min = 1;
        const int max = 16;
        if (value < min || value > max)
            Notification.NewWarning($"{item.Name}.LedOffset must be {min} to {max}");
        
        item.LedOffset = Math.Clamp(value, min, max);
        _refreshCounter++;
    }

    private void OnTopPositionChanged(Dial item, int value)
    {
        const int min = 2;
        const int max = 16;
        if (value < min || value > max)
            Notification.NewWarning($"{item.Name}.LedOffset must be {min} to {max}");
        
        item.LedOffset = Math.Clamp(value, min, max);
        _refreshCounter++;
    }
}