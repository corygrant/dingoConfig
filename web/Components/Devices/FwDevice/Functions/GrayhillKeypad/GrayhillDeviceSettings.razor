@using domain.Devices.Functions.Keypad
@using web.Services
@inject NotificationService Notification
@typeparam TDevice where TDevice : domain.Devices.FwDevice
@inherits FunctionComponentBase<TDevice>

<MudGrid Spacing="2">
    <MudItem>
        <MudCard Elevation="4" Style="height: 100%">
            <MudCardHeader>Backlight</MudCardHeader>
            <MudCardContent>
                <MudStack Spacing="4">
                    <MudNumericField Value="Keypad.BacklightBrightness"
                                     Label="Brightness (0-63)"
                                     Style="max-width: 200px"
                                     ValueChanged="@((int val) => OnBacklightBrightnessChanged(val))"/>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>
    
    <MudItem>
        <MudCard Elevation="4" Style="height: 100%">
            <MudCardHeader>Dim Backlight</MudCardHeader>
            <MudCardContent>
                <MudStack Spacing="4">
                    <MudNumericField Value="Keypad.DimBacklightBrightness"
                                     Label="Brightness (0-63)"
                                     ValueChanged="@((int val) => OnDimBacklightBrightnessChanged(val))"/>

                    <MudStack Row="false">
                        <MudText>Dimming Var</MudText>
                        <MudStack Row="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Search"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           Disabled="(!Keypad.Enabled)"
                                           Style="max-width: 20px"
                                           OnClick="@(() => OpenVariableSelectorAsync(["bool"], v => Keypad.DimmingVar = v))">
                            </MudIconButton>
                            <MudText>@GetSelectedVarText(Keypad.DimmingVar)</MudText>

                        </MudStack>
                    </MudStack>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>
    
    <MudItem>
        <MudCard Elevation="4" Style="height: 100%">
            <MudCardHeader>Buttons</MudCardHeader>
            <MudCardContent>
                <MudStack Spacing="4">
                    <MudNumericField Value="Keypad.ButtonBrightness"
                                     Label="Brightness (0-63)"
                                     Style="max-width: 200px"
                                     ValueChanged="@((int val) => OnButtonBrightnessChanged(val))"/>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>
    
    <MudItem>
        <MudCard Elevation="4" Style="height: 100%">
            <MudCardHeader>Dim Buttons</MudCardHeader>
            <MudCardContent>
                <MudStack Spacing="4">
                    <MudNumericField Value="Keypad.DimButtonBrightness"
                                     Label="Brightness (0-63)"
                                     ValueChanged="@((int val) => OnDimButtonBrightnessChanged(val))"/>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>
    
    <MudItem>
        <MudCard Elevation="4" Style="height: 100%">
            <MudCardHeader>Timeout</MudCardHeader>
            <MudCardContent>
                <MudStack Spacing="4">
                    <MudSwitch @bind-Value="@Keypad.TimeoutEnabled"
                               Color="Color.Success"
                               Label="Enabled"/>
                    <MudNumericField Value="Keypad.Timeout"
                                     Label="Timeout (ms)"
                                     ValueChanged="@((int val) => OnTimeoutChanged(val))"/>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    [Parameter, EditorRequired]
    public KeypadMaster Keypad { get; set; } = null!;
    
    private void OnBacklightBrightnessChanged(int value)
    {
        const int min = 0;
        const int max = 63;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{Keypad.Name}.BacklightBrightness must be {min} to {max}");
        }
        Keypad.BacklightBrightness = Math.Clamp(value, min, max);
    }

    private void OnDimBacklightBrightnessChanged(int value)
    {
        const int min = 0;
        const int max = 63;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{Keypad.Name}.DimBacklightBrightness must be {min} to {max}");
        }
        Keypad.DimBacklightBrightness = Math.Clamp(value, min, max);
    }

    private void OnButtonBrightnessChanged(int value)
    {
        const int min = 0;
        const int max = 63;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{Keypad.Name}.ButtonBrightness must be {min} to {max}");
        }
        Keypad.ButtonBrightness = Math.Clamp(value, min, max);
    }

    private void OnDimButtonBrightnessChanged(int value)
    {
        const int min = 0;
        const int max = 63;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{Keypad.Name}.DimButtonBrightness must be {min} to {max}");
        }
        Keypad.DimButtonBrightness = Math.Clamp(value, min, max);
    }
    
    private void OnTimeoutChanged(int value)
    {
        const int min = 0;
        const int max = 60000;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{Keypad.Name}.Timeout must be {min} to {max}");
        }
        Keypad.Timeout = Math.Clamp(value, min, max);
    }
}