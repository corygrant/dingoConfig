@using web.Components.Devices.dingoPdm.Tabs
@using web.Components.Devices.Shared
@using domain.Devices.dingoPdm
@using domain.Devices.dingoPdm.Functions.Keypad
@typeparam TDevice where TDevice : PdmDevice

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" KeepPanelsAlive="true">
    <MudTabPanel Text="Dashboard" Icon="@Icons.Material.Filled.Dashboard">
        <DashboardTab TDevice="TDevice" Device="Device" />
    </MudTabPanel>

    <MudTabPanel Text="Configuration" Icon="@Icons.Material.Filled.Settings">
        <ConfigurationTab TDevice="TDevice" Device="Device" />
    </MudTabPanel>
    
    @for (var i= 0; i < Device.Keypads.Count; i++)
    {
        if (!Device.Keypads[i].Enabled)
            continue;

        var index = i;
        var name = $"Keypad {i + 1}";
        <MudTabPanel Text=@name Icon="@Icons.Material.Filled.WbTwilight">
            <KeypadConfigTab TDevice="TDevice" Device="Device" Keypad="Device.Keypads[index]"/>
        </MudTabPanel>
    }
    
    @*
    <MudTabPanel Text="Plot" Icon="@Icons.Material.Filled.StackedLineChart">
        <PlotTab TDevice="TDevice" Device="Device" />
    </MudTabPanel>
    *@
    @*
    <MudTabPanel Text="Flow" Icon="@Icons.Material.Filled.DataExploration">
        <FlowTab />
    </MudTabPanel>
    *@
</MudTabs>

@code {
    [Parameter, EditorRequired] public TDevice Device { get; set; } = null!;
}