@using web.Services
@using web.Components.Devices.dingoPdm
@using domain.Devices.Functions
@using domain.Enums
@inject NotificationService Notification
@typeparam TDevice where TDevice : domain.Interfaces.IDeviceConfigurable
@inherits PdmFunctionComponentBase<TDevice>

<MudDataGrid Items="@Counters" Dense="true" Hover="true" Striped="false" EditMode="DataGridEditMode.Cell" ReadOnly="false"
             SortMode="SortMode.None" ColumnResizeMode="ResizeMode.Container" Virtualize="true" 
             FixedHeader="true" HorizontalScrollbar="true" Style="max-height: 400px;">
    <Columns>
        <PropertyColumn Property="x => x.Number" Title="#" StickyLeft="true" Editable="false" CellStyle="max-width: 100px"/>
        <PropertyColumn Property="x => x.Enabled">
            <EditTemplate>
                <MudCheckBox @bind-Value="context.Item.Enabled" Dense="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Name" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudTextField @bind-Value="context.Item.Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Value" Title="Value" Editable="false" CellStyle="max-width: 100px">
            <CellTemplate>
                <MudChip T="string"
                         Variant="Variant.Outlined"
                         Color="@(context.Item.Value > 0 ? Color.Success : Color.Default)"
                         Size="Size.Small" Style="min-width: 50px;">
                    @context.Item.Value
                </MudChip>
            </CellTemplate>
        </PropertyColumn>
        <TemplateColumn Title="Min" Resizable="true" CellStyle="max-width: 100px">
            <EditTemplate>
                <MudNumericField @key="@($"minCount-{context.Item.Number}-{_refreshCounter}")"
                                 Value="@context.Item.MinCount"
                                 Disabled="!context.Item.Enabled"
                                 ValueChanged="@((int val) => OnMinCountChanged(context.Item, val))"/>
            </EditTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Max" Resizable="true" CellStyle="max-width: 100px">
            <EditTemplate>
                <MudNumericField @key="@($"maxCount-{context.Item.Number}-{_refreshCounter}")"
                                 Value="@context.Item.MaxCount"
                                 Disabled="!context.Item.Enabled"
                                 ValueChanged="@((int val) => OnMaxCountChanged(context.Item, val))"/>
            </EditTemplate>
        </TemplateColumn>
        <PropertyColumn Property="x => x.WrapAround" Title="Wrap" CellStyle="max-width: 100px">
            <EditTemplate>
                <MudCheckBox @bind-Value="context.Item.WrapAround" Dense="true" Disabled="!context.Item.Enabled"/>
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.IncInput" Title="Inc Var" CellStyle="max-width: 250px;">
            <EditTemplate>
                <MudStack Row="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Search"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Disabled="(!context.Item.Enabled)"
                               Style="max-width: 20px"
                               OnClick="@(() => OpenVariableSelectorAsync(["bool"], v => context.Item.IncInput = v))">
                    </MudIconButton>
                    <MudText>@GetSelectedVarText(context.Item.IncInput)</MudText>
                </MudStack>
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.IncEdge" Title="Inc Edge" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudSelect T="InputEdge" @bind-Value="context.Item.IncEdge" Variant="Variant.Outlined" Dense="true"
                           Disabled="!context.Item.Enabled">
                    @foreach (InputEdge edge in Enum.GetValues(typeof(InputEdge)))
                    {
                        <MudSelectItem T="InputEdge" Value="@edge">@edge</MudSelectItem>
                    }
                </MudSelect>
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.DecInput" Title="Dec Var" CellStyle="max-width: 250px;">
            <EditTemplate>
                <MudStack Row="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Search"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   Disabled="(!context.Item.Enabled)"
                                   Style="max-width: 20px"
                                   OnClick="@(() => OpenVariableSelectorAsync(["bool"], v => context.Item.DecInput = v))">
                    </MudIconButton>
                    <MudText>@GetSelectedVarText(context.Item.DecInput)</MudText>
                </MudStack>
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.DecEdge" Title="Dec Edge" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudSelect T="InputEdge" @bind-Value="context.Item.DecEdge" Variant="Variant.Outlined" Dense="true"
                           Disabled="!context.Item.Enabled">
                    @foreach (InputEdge edge in Enum.GetValues(typeof(InputEdge)))
                    {
                        <MudSelectItem T="InputEdge" Value="@edge">@edge</MudSelectItem>
                    }
                </MudSelect>
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.ResetInput" Title="Reset Var" CellStyle="max-width: 250px;">
            <EditTemplate>
                <MudStack Row="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Search"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   Disabled="(!context.Item.Enabled)"
                                   Style="max-width: 20px"
                                   OnClick="@(() => OpenVariableSelectorAsync(["bool"], v => context.Item.ResetInput = v))">
                    </MudIconButton>
                    <MudText>@GetSelectedVarText(context.Item.ResetInput)</MudText>
                </MudStack>
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.ResetEdge" Title="Reset Edge" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudSelect T="InputEdge" @bind-Value="context.Item.ResetEdge" Variant="Variant.Outlined" Dense="true"
                           Disabled="!context.Item.Enabled">
                    @foreach (InputEdge edge in Enum.GetValues(typeof(InputEdge)))
                    {
                        <MudSelectItem T="InputEdge" Value="@edge">@edge</MudSelectItem>
                    }
                </MudSelect>
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.HoldToReset" Title="Hold To Reset" CellStyle="max-width: 100px">
            <EditTemplate>
                <MudCheckBox @bind-Value="context.Item.HoldToReset" Disabled="!context.Item.Enabled" Dense="true" />
            </EditTemplate>
        </PropertyColumn>
        <TemplateColumn Title="Reset Time (ms)" Resizable="true" CellStyle="max-width: 100px">
            <EditTemplate>
                <MudNumericField @key="@($"resetTime-{context.Item.Number}-{_refreshCounter}")"
                                 Value="@context.Item.ResetTime"
                                 Disabled="!context.Item.Enabled"
                                 ValueChanged="@((int val) => ResetTimeChanged(context.Item, val))"/>
            </EditTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    [Parameter, EditorRequired]
    public List<Counter> Counters { get; set; } = null!;

    private int _refreshCounter;

    private void OnMinCountChanged(Counter item, int value)
    {
        const int min = 0;
        const int max = 255;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{item.Name}.MinCount must be {min} to {max}");
        }
        item.MinCount = Math.Clamp(value, min, max);
        _refreshCounter++;
    }

    private void OnMaxCountChanged(Counter item, int value)
    {
        const int min = 0;
        const int max = 255;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{item.Name}.MaxCount must be {min} to {max}");
        }
        item.MaxCount = Math.Clamp(value, min, max);
        _refreshCounter++;
    }
    
    private void ResetTimeChanged(Counter item, int value)
    {
        const int min = 0;
        const int max = 10000;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{item.Name}.ResetTime must be {min} to {max}");
        }
        item.ResetTime = Math.Clamp(value, min, max);
        _refreshCounter++;
    }
    
}
