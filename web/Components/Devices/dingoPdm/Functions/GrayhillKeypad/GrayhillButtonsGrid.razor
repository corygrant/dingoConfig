@using domain.Devices.Functions.Keypad
@using domain.Devices.dingoPdm
@typeparam TDevice where TDevice : PdmDevice

<MudDataGrid Items="@Buttons" Dense="true" Hover="true" Striped="false" EditMode="DataGridEditMode.Cell" ReadOnly="false"
             SortMode="SortMode.None" ColumnResizeMode="ResizeMode.Container" Virtualize="false"
             FixedHeader="true" HorizontalScrollbar="true" Style="max-height: 400px;">
    <Columns>
        <PropertyColumn Property="x => x.Number" Title="#" StickyLeft="true" Editable="false" CellStyle="max-width: 100px"/>
        <PropertyColumn Property="x => x.Enabled" CellStyle="max-width: 100px">
            <EditTemplate>
                <MudCheckBox @bind-Value="context.Item.Enabled" Dense="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Name" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudTextField @bind-Value="context.Item.Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </EditTemplate>
        </PropertyColumn>
        
        @for (var i = 0; i < 4; i++)
        {
            var index = i;
            var title = $"LEDs {index}"; 
            <TemplateColumn Title=@title Resizable="true" CellStyle="max-width: 200px">
                <EditTemplate>
                    <MudSelect T="int" @bind-Value="@context.Item.Colors[index]" Variant="Variant.Outlined" Dense="true" Disabled="!context.Item.Enabled" >
                        <MudSelectItem T="int" Value="0">000</MudSelectItem>
                        <MudSelectItem T="int" Value="1">100</MudSelectItem>
                        <MudSelectItem T="int" Value="2">010</MudSelectItem>
                        <MudSelectItem T="int" Value="3">110</MudSelectItem>
                        <MudSelectItem T="int" Value="4">001</MudSelectItem>
                        <MudSelectItem T="int" Value="5">101</MudSelectItem>
                        <MudSelectItem T="int" Value="6">011</MudSelectItem>
                        <MudSelectItem T="int" Value="7">111</MudSelectItem>
                    </MudSelect>
                </EditTemplate>
            </TemplateColumn>
        }
        
        <TemplateColumn Title="Fault LEDs" Resizable="true" CellStyle="max-width: 200px">
            <EditTemplate>
                <MudSelect T="int" @bind-Value="@context.Item.FaultColor" Variant="Variant.Outlined" Dense="true" Disabled="!context.Item.Enabled" >
                    <MudSelectItem T="int" Value="0">000</MudSelectItem>
                    <MudSelectItem T="int" Value="1">100</MudSelectItem>
                    <MudSelectItem T="int" Value="2">010</MudSelectItem>
                    <MudSelectItem T="int" Value="3">110</MudSelectItem>
                    <MudSelectItem T="int" Value="4">001</MudSelectItem>
                    <MudSelectItem T="int" Value="5">101</MudSelectItem>
                    <MudSelectItem T="int" Value="6">011</MudSelectItem>
                    <MudSelectItem T="int" Value="7">111</MudSelectItem>
                </MudSelect>
            </EditTemplate>
        </TemplateColumn>

    </Columns>
</MudDataGrid>

@code {
    [Parameter, EditorRequired] public IEnumerable<Button> Buttons { get; set; } = null!;
    [Parameter, EditorRequired] public TDevice Device { get; set; } = default!;

}