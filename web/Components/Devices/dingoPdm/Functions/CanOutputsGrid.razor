@using web.Services
@using application.Services
@using domain.Devices.Functions
@inject NotificationService Notification
@inject UserPreferencesManager UserPrefs
@typeparam TDevice where TDevice : domain.Interfaces.IDeviceConfigurable
@inherits PdmFunctionComponentBase<TDevice>

<MudPaper MaxHeight="400">
    <MudDataGrid Items="@CanOutputs" Dense="true" Hover="true" Striped="false" EditMode="DataGridEditMode.Cell"
                 ReadOnly="false"
                 SortMode="SortMode.None" ColumnResizeMode="ResizeMode.Container" Virtualize="true"
                 FixedHeader="true" HorizontalScrollbar="true" Style="max-height: 400px;">
        <Columns>
            <PropertyColumn Property="x => x.Number" Title="#" StickyLeft="true" Editable="false"
                            CellStyle="max-width: 100px"/>
            <PropertyColumn Property="x => x.Enabled" CellStyle="max-width: 100px">
                <EditTemplate>
                    <MudCheckBox @bind-Value="context.Item.Enabled" Dense="true"/>
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Name" CellStyle="max-width: 200px">
                <EditTemplate>
                    <MudTextField @bind-Value="context.Item.Name" Variant="Variant.Outlined" Margin="Margin.Dense"/>
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Input" Title="Variable" CellStyle="max-width: 250px;">
                <EditTemplate>
                    <MudStack Row="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Search"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       Disabled="(!context.Item.Enabled)"
                                       Style="max-width: 20px"
                                       OnClick="@(() => OpenVariableSelectorAsync(["bool", "int", "float"], v => context.Item.Input = v))">
                        </MudIconButton>
                        <MudText>@GetSelectedVarText(context.Item.Input)</MudText>
                    </MudStack>
                </EditTemplate>
            </PropertyColumn>
            <TemplateColumn Title="ID" Resizable="true" CellStyle="max-width: 100px">
                <EditTemplate>
                    <MudTextField @key="@($"id-{context.Item.Number}-{_refreshCounter}")"
                                  Value="@_id[context.Item.Number-1]"
                                  Disabled="!context.Item.Enabled"
                                  ValueChanged="@((string val) => @context.Item.Id = Utils.ParseId(val, UserPrefs.Preferences.IdFormat, Notification))"
                                  Step="1"/>
                </EditTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Ide" Title="Extended" CellStyle="max-width: 100px">
                <EditTemplate>
                    <MudCheckBox @bind-Value="context.Item.Ide" Disabled="true" Dense="true"/>
                </EditTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Start Bit" Resizable="true" CellStyle="max-width: 100px">
                <EditTemplate>
                    <MudNumericField @key="@($"startBit-{context.Item.Number}-{_refreshCounter}")"
                                     Value="@context.Item.StartBit"
                                     Disabled="!context.Item.Enabled"
                                     ValueChanged="@((int val) => OnStartBitChanged(context.Item, val))"
                                     Step="1"/>
                </EditTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Bit Length" Resizable="true" CellStyle="max-width: 100px">
                <EditTemplate>
                    <MudNumericField @key="@($"bitLength-{context.Item.Number}-{_refreshCounter}")"
                                     Value="@context.Item.BitLength"
                                     Disabled="!context.Item.Enabled"
                                     ValueChanged="@((int val) => OnBitLengthChanged(context.Item, val))"
                                     Step="1"/>
                </EditTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Factor" Title="Factor" Resizable="true" CellStyle="max-width: 100px">
                <EditTemplate>
                    <MudNumericField @bind-Value="@context.Item.Factor"
                                     Format="G6"
                                     Disabled="!context.Item.Enabled"/>
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Offset" Title="Offset" Resizable="true" CellStyle="max-width: 100px">
                <EditTemplate>
                    <MudNumericField @bind-Value="@context.Item.Offset"
                                     Format="G6"
                                     Disabled="!context.Item.Enabled"/>
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Signed" CellStyle="max-width: 100px">
                <EditTemplate>
                    <MudCheckBox @bind-Value="context.Item.Signed" Dense="true"/>
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ByteOrder" CellStyle="max-width: 200px">
                <EditTemplate>
                    <MudSelect T="domain.Enums.ByteOrder" @bind-Value="context.Item.ByteOrder" Variant="Variant.Outlined"
                               Disabled="!context.Item.Enabled" Dense="true">
                        @foreach (domain.Enums.ByteOrder order in Enum.GetValues(typeof(domain.Enums.ByteOrder)))
                        {
                            <MudSelectItem T="domain.Enums.ByteOrder" Value="@order">@order</MudSelectItem>
                        }
                    </MudSelect>
                </EditTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Interval (ms)" Resizable="true" CellStyle="max-width: 150px">
                <EditTemplate>
                    <MudNumericField @key="@($"interval-{context.Item.Number}-{_refreshCounter}")"
                                     Value="@context.Item.Interval"
                                     Disabled="!context.Item.Enabled"
                                     ValueChanged="@((int val) => OnIntervalChanged(context.Item, val))"/>
                </EditTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>
</MudPaper>

@code {
    [Parameter, EditorRequired] public List<CanOutput> CanOutputs { get; set; } = null!;

    private string[] _id;
    
    private int _refreshCounter;

    protected override Task OnInitializedAsync()
    {
        _id = new string[CanOutputs.Count];
        
        return Task.CompletedTask;
    }
    
    protected override void OnParametersSet()
    {
        foreach (var input in CanOutputs)
        {
            _id[input.Number - 1] = Utils.FormatId(input.Id, UserPrefs.Preferences.IdFormat);
        }
        
        StateHasChanged();

        base.OnParametersSet();
    }

    private void OnBitLengthChanged(CanOutput item, int value)
    {
        const int min = 1;
        const int max = 32;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{item.Name}.BitLength must be {min} to {max}");
        }

        item.BitLength = Math.Clamp(value, min, max);
        _refreshCounter++;
    }

    private void OnStartBitChanged(CanOutput item, int value)
    {
        const int min = 0;
        const int max = 64;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{item.Name}.StartBit must be {min} to {max}");
        }

        item.StartBit = Math.Clamp(value, min, max);
        _refreshCounter++;
    }

    private void OnIntervalChanged(CanOutput item, int value)
    {
        const int min = 0;
        const int max = 60000;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{item.Name}.Interval must be {min} to {max}");
        }

        item.Interval = Math.Clamp(value, min, max);
        _refreshCounter++;
    }
}
