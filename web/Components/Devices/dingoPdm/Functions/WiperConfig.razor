@using web.Services
@using web.Components.Devices.dingoPdm
@using domain.Devices.Functions
@using domain.Enums
@inject NotificationService Notification
@typeparam TDevice where TDevice : domain.Interfaces.IDeviceConfigurable
@inherits PdmFunctionComponentBase<TDevice>

<MudCard Outlined="true" Class="mb-2">
    <MudCardContent>
        <MudGrid Spacing="5">
            <MudItem>
                <MudCard Elevation="4" Style="width: 250px; height: 100%">
                    <MudCardHeader>
                        <MudText Typo="Typo.h6" Class="mt-2">Enable</MudText>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudTextField @bind-Value="Wiper.Name"
                                      Label="Name"
                                      Variant="Variant.Outlined"/>
                        <MudSwitch @bind-Value="Wiper.Enabled"
                                   Label="Enabled"
                                   Color="Color.Primary"/>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem>
                <MudCard Elevation="4" Style="width: 250px; height: 100%">
                    <MudCardHeader>
                        <MudText Typo="Typo.h6" Class="mt-2">Mode</MudText>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSelect Value="Wiper.Mode"
                                   Label="Wiper Mode"
                                   ValueChanged="@((WiperMode val) => OnModeSelected(val))"
                                   Disabled="!Wiper.Enabled"
                                   Variant="Variant.Outlined">
                            @foreach (WiperMode mode in Enum.GetValues(typeof(WiperMode)))
                            {
                                <MudSelectItem Value="@mode">@mode</MudSelectItem>
                            }
                        </MudSelect>
                        <MudSwitch @bind-Value="Wiper.ParkStopLevel"
                                   Label="Park Stop Level"
                                   Color="Color.Primary"/>
                        <MudNumericField @key="@($"washWipeCycles-{_refreshCounter}")"
                                         Value= "Wiper.WashWipeCycles"
                                         Label="Wash Wipe Cycles"
                                         Variant="Variant.Outlined"
                                         Disabled="!Wiper.Enabled"
                                         ValueChanged="@((int val) => OnWashWipeCyclesChanged(Wiper, val))"/>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem>
                <MudCard Elevation="4" Style="width: 250px; height: 100%">
                    <MudCardHeader>
                        <MudText Typo="Typo.h6" Class="mt-2">Required Inputs</MudText>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudCard Elevation="4">
                            <MudCardContent>
                                <MudText Class="fst-italic">Park</MudText>
                                <MudStack Row="true">
                                    <MudIconButton Icon="@Icons.Material.Filled.Search"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   Disabled="(!Wiper.Enabled)"
                                                   Style="max-width: 20px"
                                                   OnClick="@(() => OpenVariableSelectorAsync(["bool"], v => Wiper.ParkInput = v))">
                                    </MudIconButton>
                                    <MudText>@GetSelectedVarText(Wiper.ParkInput)</MudText>
                                </MudStack>
                            </MudCardContent>
                        </MudCard>
                    </MudCardContent>
                </MudCard>
            </MudItem>
            
            <MudItem>
                <MudCard Elevation="4" Style="width: 250px; height: 100%">
                <MudCardHeader>
                    <MudText Typo="Typo.h6" Class="mt-2">Mode Inputs</MudText>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid>
                        <MudItem>
                            <MudCard Elevation="4">
                                <MudCardContent>
                                    <MudText Class="fst-italic">Slow</MudText>
                                    <MudStack Row="true">
                                        <MudIconButton Icon="@Icons.Material.Filled.Search"
                                                       Color="Color.Primary"
                                                       Size="Size.Small"
                                                       Disabled="(!Wiper.Enabled || _slowInputDisabled)"
                                                       Style="max-width: 20px"
                                                       OnClick="@(() => OpenVariableSelectorAsync(["bool"], v => Wiper.SlowInput = v))">
                                        </MudIconButton>
                                        <MudText>@GetSelectedVarText(Wiper.SlowInput)</MudText>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem>
                            <MudCard Elevation="4">
                                <MudCardContent>
                                    <MudText Class="fst-italic">Fast</MudText>
                                    <MudStack Row="true">
                                        <MudIconButton Icon="@Icons.Material.Filled.Search"
                                                       Color="Color.Primary"
                                                       Size="Size.Small"
                                                       Disabled="(!Wiper.Enabled || _fastInputDisabled)"
                                                       Style="max-width: 20px"
                                                       OnClick="@(() => OpenVariableSelectorAsync(["bool"], v => Wiper.FastInput = v))">
                                        </MudIconButton>
                                        <MudText>@GetSelectedVarText(Wiper.FastInput)</MudText>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem>
                            <MudCard Elevation="4">
                                <MudCardContent>
                                    <MudText Class="fst-italic">Intermittent</MudText>
                                    <MudStack Row="true">
                                        <MudIconButton Icon="@Icons.Material.Filled.Search"
                                                       Color="Color.Primary"
                                                       Size="Size.Small"
                                                       Disabled="(!Wiper.Enabled || _interInputDisabled)"
                                                       Style="max-width: 20px"
                                                       OnClick="@(() => OpenVariableSelectorAsync(["bool"], v => Wiper.InterInput = v))">
                                        </MudIconButton>
                                        <MudText>@GetSelectedVarText(Wiper.InterInput)</MudText>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem>
                            <MudCard Elevation="4">
                                <MudCardContent>
                                    <MudText Class="fst-italic">On</MudText>
                                    <MudStack Row="true">
                                        <MudIconButton Icon="@Icons.Material.Filled.Search"
                                                       Color="Color.Primary"
                                                       Size="Size.Small"
                                                       Disabled="(!Wiper.Enabled || _onInputDisabled)"
                                                       Style="max-width: 20px"
                                                       OnClick="@(() => OpenVariableSelectorAsync(["bool"], v => Wiper.OnInput = v))">
                                        </MudIconButton>
                                        <MudText>@GetSelectedVarText(Wiper.OnInput)</MudText>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem>
                            <MudCard Elevation="4">
                                <MudCardContent>
                                    <MudText Class="fst-italic">Speed</MudText>
                                    <MudStack Row="true">
                                        <MudIconButton Icon="@Icons.Material.Filled.Search"
                                                       Color="Color.Primary"
                                                       Size="Size.Small"
                                                       Disabled="(!Wiper.Enabled || _speedInputDisabled)"
                                                       Style="max-width: 20px"
                                                       OnClick="@(() => OpenVariableSelectorAsync(["int"], v => Wiper.SpeedInput = v))">
                                        </MudIconButton>
                                        <MudText>@GetSelectedVarText(Wiper.SpeedInput)</MudText>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    </MudGrid>
                    </MudCardContent>
                </MudCard>
            </MudItem>
            
            <MudItem>
                <MudCard Elevation="4" Style="width: 250px; height: 100%">
                    <MudCardHeader>
                        <MudText Typo="Typo.h6" Class="mt-2">Optional Inputs</MudText>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudGrid>
                            <MudItem>
                                <MudCard Elevation="4">
                                    <MudCardContent>
                                        <MudText Class="fst-italic">Swipe</MudText>
                                        <MudStack Row="true">
                                            <MudIconButton Icon="@Icons.Material.Filled.Search"
                                                           Color="Color.Primary"
                                                           Size="Size.Small"
                                                           Disabled="(!Wiper.Enabled)"
                                                           Style="max-width: 20px"
                                                           OnClick="@(() => OpenVariableSelectorAsync(["bool"], v => Wiper.SwipeInput = v))">
                                            </MudIconButton>
                                            <MudText>@GetSelectedVarText(Wiper.SwipeInput)</MudText>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                            <MudItem>
                                <MudCard Elevation="4">
                                    <MudCardContent>
                                        <MudText Class="fst-italic">Wash</MudText>
                                        <MudStack Row="true">
                                            <MudIconButton Icon="@Icons.Material.Filled.Search"
                                                           Color="Color.Primary"
                                                           Size="Size.Small"
                                                           Disabled="(!Wiper.Enabled)"
                                                           Style="max-width: 20px"
                                                           OnClick="@(() => OpenVariableSelectorAsync(["bool"], v => Wiper.WashInput = v))">
                                            </MudIconButton>
                                            <MudText>@GetSelectedVarText(Wiper.WashInput)</MudText>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem>
                <MudCard Elevation="4" Style="width: 250px; height: 100%">
                    <MudCardHeader>
                        <MudText Typo="Typo.h6" Class="mt-2">Speed Map</MudText>
                    </MudCardHeader>
                    <MudCardContent>
                        @for (int i = 0; i < 4; i++)
                        {
                            var index = i; // Capture for lambda
                            <MudSelect @bind-Value="Wiper.SpeedMap[index]"
                                       Label="@($"Speed {index}")"
                                       Variant="Variant.Outlined"
                                       Disabled="@(!Wiper.Enabled || _speedInputDisabled)">
                                @foreach (WiperSpeed speed in Enum.GetValues(typeof(WiperSpeed)))
                                {
                                    <MudSelectItem Value="@speed">@speed</MudSelectItem>
                                }
                            </MudSelect>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
            
            <MudItem>
                <MudCard Elevation="4" Style="width: 250px; height: 100%">
                    <MudCardHeader>
                        <MudText Typo="Typo.h6" Class="mt-2">Speed Map</MudText>
                    </MudCardHeader>
                    <MudCardContent>
                        @for (int i = 4; i < 8; i++)
                        {
                            var index = i; // Capture for lambda
                            <MudSelect @bind-Value="Wiper.SpeedMap[index]"
                                       Label="@($"Speed {index}")"
                                       Variant="Variant.Outlined"
                                       Disabled="@(!Wiper.Enabled || _speedInputDisabled)">
                                @foreach (WiperSpeed speed in Enum.GetValues(typeof(WiperSpeed)))
                                {
                                    <MudSelectItem Value="@speed">@speed</MudSelectItem>
                                }
                            </MudSelect>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
            
            <MudItem>
                <MudCard Elevation="4" Style="width: 250px; height: 100%">
                    <MudCardHeader>
                        <MudText Typo="Typo.h6" Class="mt-2">Intermittent Delays (s)</MudText>
                    </MudCardHeader>
                    <MudCardContent>
                        @for (int i = 0; i < 3; i++)
                        {
                            var index = i; // Capture for lambda
                            <MudNumericField @key="@($"intermit-{index}-{_refreshCounter}")"
                                             Value= "Wiper.IntermitTime[index]"
                                             Label="@($"Delay {index}")"
                                             Variant="Variant.Outlined"
                                             Disabled="!Wiper.Enabled"
                                             ValueChanged="@((int val) => OnIntermitTimeChanged(Wiper, index, val))"/>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
            
            <MudItem>
                <MudCard Elevation="4" Style="width: 250px; height: 100%">
                    <MudCardHeader>
                        <MudText Typo="Typo.h6" Class="mt-2">Intermittent Delays (s)</MudText>
                    </MudCardHeader>
                    <MudCardContent>
                        @for (int i = 3; i < 6; i++)
                        {
                            var index = i; // Capture for lambda
                            <MudNumericField @key="@($"intermit-{index}-{_refreshCounter}")"
                                             Value= "Wiper.IntermitTime[index]"
                                             Label="@($"Delay {index}")"
                                             Variant="Variant.Outlined"
                                             Disabled="!Wiper.Enabled"
                                             ValueChanged="@((int val) => OnIntermitTimeChanged(Wiper, index, val))"/>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired] public Wiper Wiper { get; set; } = null!;
    
    private bool _slowInputDisabled;
    private bool _fastInputDisabled;
    private bool _interInputDisabled;
    private bool _onInputDisabled;
    private bool _speedInputDisabled;

    private int _refreshCounter;
    
    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        SetInputsEnabled();
    }

    private void OnModeSelected(WiperMode value)
    {
        Wiper.Mode = value;
        SetInputsEnabled();
    }

    private void SetInputsEnabled()
    {
        switch (Wiper.Mode)
        {
            case WiperMode.DigIn:
                _onInputDisabled = true;
                _speedInputDisabled = true;

                _slowInputDisabled = false;
                _fastInputDisabled = false;
                _interInputDisabled = false;
                break;
            case WiperMode.IntIn:
                _slowInputDisabled = true;
                _fastInputDisabled = true;
                _interInputDisabled = true;
                _onInputDisabled = true;

                _speedInputDisabled = false;
                break;
            case WiperMode.MixIn:
                _slowInputDisabled = true;
                _fastInputDisabled = true;
                _interInputDisabled = true;

                _onInputDisabled = false;
                _speedInputDisabled = false;
                break;
            default:
                throw new ArgumentOutOfRangeException();
        }
    }
    
    private void OnIntermitTimeChanged(Wiper wiper, int index, int value)
    {
        const int min = 0;
        const int max = 30000;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{Wiper.Name}.IntermitTime[{index}] must be {min} to {max}");
        }
        wiper.IntermitTime[index] = Math.Clamp(value, min, max);
        _refreshCounter++;
    }
    
    private void OnWashWipeCyclesChanged(Wiper wiper, int value)
    {
        const int min = 0;
        const int max = 10;
        if (value < min || value > max)
        {
            Notification.NewWarning($"{Wiper.Name}.WashWipeCycles must be {min} to {max}");
        }
        wiper.WashWipeCycles = Math.Clamp(value, min, max);
        _refreshCounter++;
    }
}
